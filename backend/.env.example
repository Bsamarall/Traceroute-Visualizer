# ============================================================
# Traceroute Visualizer - Environment Variables
# ============================================================
# Copie este arquivo para .env e ajuste os valores

# Porta do servidor
PORT=3001

# Ambiente (development | production)
NODE_ENV=development

# Origem permitida para CORS (URL do frontend)
ALLOWED_ORIGIN=http://localhost:5173

# Rate limiting - requisições por janela de tempo
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Timeout do traceroute em milissegundos
TRACEROUTE_TIMEOUT_MS=30000

# Máximo de hops do traceroute
TRACEROUTE_MAX_HOPS=30

# API de geolocalização (ip-api.com é gratuita sem key)
GEO_API_URL=http://ip-api.com/json

# Tempo de cache para geolocalização (em segundos)
GEO_CACHE_TTL=3600

# Caminho do banco de dados SQLite
DB_PATH=./data/traceroute.db

# Nível de log (error | warn | info | debug)
LOG_LEVEL=info
